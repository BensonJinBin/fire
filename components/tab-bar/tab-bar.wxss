/* components/tab-bar/tab-bar.wxss */
.custom-bottom-nav {
  position: fixed;
  bottom: 30rpx;
  left: 50rpx;
  right: 50rpx;
  background-color: #000;
  height: 100rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 15rpx 0;
  z-index: 1000;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  padding: 5rpx;
  transition: all 0.3s ease;
}

.nav-item.active {
  color: #D0F070;
}

.nav-item.active .nav-icon {
  filter: brightness(0) saturate(100%) invert(84%) sepia(44%) saturate(490%) hue-rotate(30deg) brightness(102%) contrast(88%) !important;
}

.nav-item .nav-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 4rpx;
  filter: brightness(0) invert(1);
}

.nav-item .nav-text {
  font-size: 24rpx;
  line-height: 1;
}

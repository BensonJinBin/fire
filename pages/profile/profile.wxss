/* pages/profile/profile.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  width: 100%;
  background-color: #D0F070;
}

.custom-nav {
  background-color: #D0F070;
  padding: 20rpx 20rpx 30rpx;
  text-align: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.content {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.section-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}
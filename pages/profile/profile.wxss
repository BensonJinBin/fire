/* pages/profile/profile.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  width: 100%;
  background-color: #3DBEA0;
}

.custom-nav {
  background-color: #3DBEA0;
  padding: 20rpx 20rpx 30rpx;
  text-align: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.feature-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #FF6B35 0%, #FF8C61 100%);
}

.feature-card.calculator-card::before {
  background: linear-gradient(180deg, #4A90E2 0%, #5BA3F5 100%);
}

.feature-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-icon-arbitrage {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C61 100%);
  color: white;
}

.feature-icon-calculator {
  background: linear-gradient(135deg, #4A90E2 0%, #5BA3F5 100%);
  color: white;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
}

.feature-arrow {
  font-size: 48rpx;
  color: #ccc;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.content {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.section-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}

/* 卡片容器 */
.card {
  background: white;
  border-radius: 16rpx;
  box-shadow: 4rpx 8rpx 24rpx rgba(0,0,0,0.15);
  margin-bottom: 0rpx;
  margin: 16rpx;
  overflow: hidden;
  border: 1rpx solid #e0e0e0;
}

/* 分享模块样式 */
.share-section {
  padding: 16rpx;
}

.share-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-top: 8rpx;
}

.share-text {
  font-size: 28rpx;
  color: #666;
  flex: 1;
  line-height: 1.5;
}

.share-btn {
  background-color: #3DBEA0;
  background: linear-gradient(135deg, #3DBEA0 0%, #2FA38A 100%);
  color: #333;
  border-radius: 8rpx;
  border: none;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  font-weight: bold;
  margin-top: 16rpx;
  width: auto;
  max-width: 120rpx;
}

.share-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.share-btn::after {
  border: none;
}

.share-button {
  width: 56rpx;
  height: 56rpx;
  background-color: #3DBEA0;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
}

.share-icon {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

/* 功能说明模块样式 */
.features-section {
  padding: 16rpx;
}

.features-description {
  margin-top: 24rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  text-align: justify;
}

.features-list {
  margin-top: 24rpx;
}

.feature-item {
  margin-bottom: 24rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  display: block;
}
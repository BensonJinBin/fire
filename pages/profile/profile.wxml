<!-- pages/profile/profile.wxml -->
<view class="page-content">
  <!-- 自定义顶部区域，用于适配安全区域 -->
  <view class="status-bar" style="height:{{statusBarHeight}}px;"></view>
  <view class="custom-nav">
    <text class="nav-title">工具</text>
  </view>

  <view class="feature-card" bindtap="navigateToArbitrage">
    <view class="feature-icon feature-icon-arbitrage">¥</view>
    <view class="feature-info">
      <text class="feature-title">LOF套利</text>
      <text class="feature-desc">实时查看LOF基金溢价率，发现套利机会</text>
    </view>
    <view class="feature-arrow">›</view>
  </view>

  <view class="feature-card calculator-card" bindtap="navigateToCalculator">
    <view class="feature-icon feature-icon-calculator">🔢</view>
    <view class="feature-info">
      <text class="feature-title">Fire计算器</text>
      <text class="feature-desc">规划您的财务自由之路，计算退休所需时间</text>
    </view>
    <view class="feature-arrow">›</view>
  </view>
  
  <view class="content">
    <!-- 分享模块 -->
    <view class="card">
      <view class="share-section">
        <text class="section-title">分享</text>
        <view class="share-content">
          <text class="share-text">觉得这个App不错？马上分享给大家！</text>
          <button class="share-btn" open-type="share">
            <image class="share-icon-img" src="/icons/share.svg" mode="scaleToFill"></image>
          </button>
        </view>
      </view>
    </view>

    <ad unit-id="adunit-5c28703d6d3e2c5b" bindload="adLoad" binderror="adError" bindclose="adClose"></ad>
  </view>
</view>

<!-- 自定义底部导航栏 -->
<view class="custom-bottom-nav">
  <view class="nav-item" bindtap="navigateToIndex">
    <image class="nav-icon" src="/icons/home.png"></image>
    <text class="nav-text">首页</text>
  </view>
  <view class="nav-item" bindtap="navigateToCalculator">
    <image class="nav-icon" src="/icons/calculator.png"></image>
    <text class="nav-text">计算器</text>
  </view>
  <view class="nav-item active">
    <image class="nav-icon" src="/icons/setting.png"></image>
    <text class="nav-text">工具</text>
  </view>
</view>
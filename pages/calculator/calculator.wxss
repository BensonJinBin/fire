/* pages/calculator/calculator.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  width: 100%;
  background-color: #D0F070;
}

.custom-nav {
  background-color: #D0F070;
  padding: 20rpx 20rpx 30rpx;
  text-align: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.form {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.calculate-btn {
  background-color: #D0F070;
  color: #000;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
  font-size: 28rpx;
  margin: 0;
  border: none;
  box-sizing: border-box;
  line-height: 80rpx;
  text-align: center;
  width: 100%;
}

.calculate-btn:active {
  background-color: #C0E65C;
}

.results {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.results-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.table-container {
  width: 100%;
  overflow-x: auto;
  margin-bottom: 30rpx;
}

.table-header, .table-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  border-bottom: 1rpx solid #eee;
  padding: 15rpx 0;
}

.table-header {
  background-color: #f9f9f9;
  font-weight: bold;
}

.col-year, .col-expense, .col-interest, .col-principal {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #333;
}

.col-year {
  flex: 0.8;
}

.analysis {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.analysis-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.analysis-item {
  margin-bottom: 15rpx;
}

.analysis-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
}
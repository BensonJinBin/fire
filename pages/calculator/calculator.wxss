/* pages/calculator/calculator.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  width: 100%;
  background-color: #3DBEA0;
}

.custom-nav {
  background-color: #3DBEA0;
  padding: 20rpx 20rpx 30rpx;
  text-align: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.form {
  background: white;
  border-radius: 10rpx;
  padding: 10rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.group-container {
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}

.group1 {
  background-color: #F0FBF8;
  border: 1rpx solid #B8E8DC;
}

.group2 {
  background-color: #F5FFF0;
  border: 1rpx solid #D6F5C8;
}

.group3 {
  background-color: #f0fbf8;
  border: 1rpx solid #b8e8dc;
}

.group-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
  font-weight: bold;
}

.input-group {
  margin-bottom: 25rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.hint-text {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.derived-value {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #f8f8f8;
  color: #666;
}

.output-value {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #f8f8f8;
  color: #666;
}

.slider-with-percentage {
  display: flex;
  align-items: center;
}

.slider-container {
  flex: 1;
  position: relative;
}

.slider-percentage {
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  min-width: 60rpx;
  text-align: center;
  pointer-events: none; /* 确保百分号文本不阻挡滑动操作 */
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-default {
  color: #999;
}

.radio-label {
  display: inline-flex;
  align-items: center;
}

.radio-label.selected {
  color: #333;
  font-weight: bold;
}

.radio-label.unselected {
  color: #999;
}

.radio-text {
  margin-left: 10rpx;
  font-size: 26rpx;
}

.mode-description {
  display: block;
  margin-left: 40rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.mode-description.selected {
  color: #333;
  font-weight: normal;
}

.mode-description.unselected {
  color: #999;
}

.calculate-btn {
  background-color: #3DBEA0;
  background: linear-gradient(135deg, #3DBEA0 0%, #2FA38A 100%);
  color: #333;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
  font-size: 28rpx;
  margin: 0;
  border: none;
  box-sizing: border-box;
  line-height: 80rpx;
  text-align: center;
  width: 100%;
}

.calculate-btn:active {
  background: linear-gradient(135deg, #2FA38A 0%, #238B75 100%);
}

.clear-btn {
  background-color: #f8f8f8;
  color: #000;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
  font-size: 28rpx;
  margin: 20rpx 0 0 0;
  border: none;
  box-sizing: border-box;
  line-height: 80rpx;
  text-align: center;
  width: 100%;
}

.clear-btn:active {
  background-color: #e0e0e0;
}

.results {
  background: #F5FDFC;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  border: 1rpx solid #B8E8DC;
}

.results-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F7D6A;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #B8E8DC;
}

.table-container {
  width: 100%;
  overflow-x: auto;
  margin-bottom: 30rpx;
}

.table-header, .table-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  border-bottom: 1rpx solid #eee;
  padding: 15rpx 0;
}

.table-header {
  background-color: #E8F8F4;
  font-weight: bold;
  color: #1F7D6A;
}

.col-year, .col-expense, .col-interest, .col-principal {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #333;
}

.col-year {
  flex: 0.8;
}

.analysis {
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.analysis-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
  display: block;
  margin-bottom: 8rpx;
  text-align: center;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.analysis-subtitle {
  font-size: 30rpx;
  font-weight: bold;
  color: #555;
  margin: 20rpx 0 15rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #3DBEA0;
}

.analysis-data-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.analysis-data-row:last-child {
  border-bottom: none;
}

.analysis-label {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.analysis-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  min-width: 150rpx;
}

.analysis-value.highlight {
  color: #1F7D6A;
  font-weight: bold;
}

.analysis-value.green-highlight {
  color: #1F7D6A;
  font-weight: bold;
  font-size: 32rpx;
}

.analysis-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  padding: 8rpx 0;
  text-align: left;
}
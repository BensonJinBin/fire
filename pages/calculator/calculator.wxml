<!-- pages/calculator/calculator.wxml -->
<view class="page-content">
  <!-- 自定义顶部区域，用于适配安全区域 -->
  <view class="status-bar" style="height:{{statusBarHeight}}px;"></view>
  <view class="custom-nav">
    <text class="nav-title">Fire计算器</text>
  </view>
  
  <view class="form">
    <!-- 组1：当前财务状况 -->
    <view class="group-container group1">
      <text class="group-title">当前财务状况</text>
      
      <view class="input-group">
        <text class="label">当前储蓄总金额 (元)</text>
        <input class="{{principalInputClass || 'input input-default'}}" type="digit" bindinput="handleInput" bindfocus="handleFocus" bindblur="handleBlur" data-field="principal" value="{{principal}}" />
      </view>
      
      <!-- 模式切换器 -->
      <view class="input-group">
        <radio-group bindchange="onFinanceModeChange">
          <label class="radio-label {{financeMode === 'expense' ? 'selected' : 'unselected'}}">
            <radio value="expense" checked="{{financeMode === 'expense'}}" color="#F5A623" />
            <text class="radio-text">收入/支出模式</text>
          </label>
          <label class="radio-label {{financeMode === 'saving' ? 'selected' : 'unselected'}}" style="margin-left: 40rpx;">
            <radio value="saving" checked="{{financeMode === 'saving'}}" color="#F5A623" />
            <text class="radio-text">储蓄模式</text>
          </label>
        </radio-group>
      </view>
      
      <!-- 根据模式显示不同的输入框 -->
      <view wx:if="{{financeMode === 'expense'}}">
        <view class="input-group">
          <text class="label">年收入 (元)</text>
          <input class="{{incomeInputClass || 'input input-default'}}" type="digit" bindinput="onIncomeInput" bindfocus="handleFocus" bindblur="onIncomeBlur" data-field="income" value="{{income}}" />
        </view>
        <view class="input-group">
          <text class="label">年支出 (元)</text>
          <input class="{{expenseInputClass || 'input input-default'}}" type="digit" bindinput="onExpenseInput" bindfocus="handleFocus" bindblur="onExpenseBlur" data-field="expense" value="{{expense}}" />
        </view>
        <view class="input-group">
          <text class="label">储蓄率 (%)</text>
          <view class="slider-with-percentage">
            <view class="slider-container">
              <slider bindchange="onSavingsRateChange" value="{{savingsRate}}" min="0" max="100" block-size="20" />
            </view>
            <text class="slider-percentage">{{savingsRate}}%</text>
          </view>
        </view>
      </view>
      
      <view wx:elif="{{financeMode === 'saving'}}">
        <view class="input-group">
          <text class="label">每年储蓄金额 (元)</text>
          <input class="{{savingInputClass || 'input input-default'}}" type="digit" bindinput="onSavingInput" bindfocus="handleFocus" bindblur="onSavingBlur" data-field="saving" value="{{saving}}" />
          <text class="hint-text">您每年计划存入的资金</text>
        </view>
      </view>
    </view>
    
    <!-- 组2：市场与经济假设 -->
    <view class="group-container group2">
      <text class="group-title">市场与经济假设</text>
      <view class="input-group">
        <text class="label">平均投资回报 (%)</text>
        <input class="{{interestRateInputClass || 'input input-default'}}" type="digit" bindinput="handleInput" bindfocus="handleFocus" bindblur="handleBlur" data-field="interestRate" value="{{interestRate}}" />
        <text class="hint-text">普通理财产品的年化收益率约为3%</text>
      </view>
      
      <view class="input-group" wx:if="{{financeMode === 'expense'}}">
        <text class="label">通胀率 (%)</text>
        <input class="{{inflationRateInputClass || 'input input-default'}}" type="digit" bindinput="handleInput" bindfocus="handleFocus" bindblur="handleBlur" data-field="inflationRate" value="{{inflationRate}}" />
        <text class="hint-text">年通胀率一般在2%-3%​之间</text>
      </view>
    </view>
    
    <!-- 组3：预测目标 -->
    <view class="group-container group3">
      <text class="group-title">预测目标</text>
      <view class="input-group">
        <radio-group bindchange="onModeChange">
          <!-- 支出模式下显示两个选项 -->
          <block wx:if="{{financeMode === 'expense'}}">
            <label class="radio-label {{isTargetMode ? 'selected' : 'unselected'}}">
              <radio value="target" checked="{{isTargetMode}}" color="#F5A623" />
              <text class="radio-text">目标模式</text>
            </label>
            <text class="mode-description {{isTargetMode ? 'selected' : 'unselected'}}">我想知道多少年后能退休(投资收益大于支出)</text>
            
            <label class="radio-label {{!isTargetMode ? 'selected' : 'unselected'}}" style="margin-top: 20rpx;">
              <radio value="prediction" checked="{{!isTargetMode}}" color="#F5A623" />
              <text class="radio-text">预测模式</text>
            </label>
            <text class="mode-description {{!isTargetMode ? 'selected' : 'unselected'}}">我想知道N年后有多少钱</text>
          </block>
          
          <!-- 储蓄模式下只显示预测模式 -->
          <block wx:if="{{financeMode === 'saving'}}">
            <label class="radio-label selected">
              <radio value="prediction" checked="true" color="#F5A623" />
              <text class="radio-text">预测模式</text>
            </label>
            <text class="mode-description selected">我想知道N年后有多少钱</text>
          </block>
        </radio-group>
      </view>
      
      <view wx:if="{{!isTargetMode}}" class="input-group">
        <text class="label">计算年数</text>
        <input class="{{yearsInputClass || 'input input-default'}}" type="number" bindinput="handleInput" bindfocus="handleFocus" bindblur="handleBlur" data-field="years" value="{{years}}" />
      </view>
    </view>
    
    <view class="calculate-btn" bindtap="calculate">开始计算</view>
    <view id="results-placeholder"></view>
    <view class="clear-btn" bindtap="clearInputs">重置</view>
  </view>

  <view class="analysis" wx:if="{{results.length > 0}}">
    <text class="analysis-title">目标达成概况</text>
    <!-- <text class="analysis-subtitle">财务状况概况</text> -->
    
    <!-- 使用数据行格式显示关键信息 -->
    <view class="analysis-data-row">
      <text class="analysis-label">{{isTargetMode ? '所需年数:' : '计算年数:'}}</text>
      <text class="analysis-value {{isTargetMode ? 'green-highlight' : ''}}">{{results.length}}</text>
    </view>
    
    <view class="analysis-data-row">
      <text class="analysis-label">最终本金 (元):</text>
      <text class="analysis-value highlight">{{results[results.length-1] ? results[results.length-1].principal : '0.00'}}</text>
    </view>
    
    <!-- 支出模式下显示年支出和FIRE条件 -->
    <block wx:if="{{financeMode === 'expense'}}">
      <view class="analysis-data-row">
        <text class="analysis-label">最终年支出 (元):</text>
        <text class="analysis-value">{{results[results.length-1] ? results[results.length-1].expense : '0.00'}}</text>
      </view>
      
      <view class="analysis-data-row">
        <text class="analysis-label">最终年收益 (元):</text>
        <text class="analysis-value">{{results[results.length-1] ? results[results.length-1].interest : '0.00'}}</text>
      </view>
      
      <view class="analysis-data-row">
        <text class="analysis-label">是否达到Fire条件:</text>
        <text class="analysis-value highlight">{{results[results.length-1] && results[results.length-1].interest >= results[results.length-1].expense ? '是' : '否'}}</text>
      </view>
    </block>
    
    <!-- 储蓄模式下只显示年收益 -->
    <block wx:if="{{financeMode === 'saving'}}">
      <view class="analysis-data-row">
        <text class="analysis-label">最终年收益 (元):</text>
        <text class="analysis-value">{{results[results.length-1] ? results[results.length-1].interest : '0.00'}}</text>
      </view>
    </block>
    
    <view class="analysis-subtitle" wx:if="{{analysis.length > 0}}">分析建议</view>
    <view wx:for="{{analysis}}" wx:key="index" wx:if="{{analysis.length > 0}}">
      <view class="analysis-data-row">
        <text class="analysis-text">{{item}}</text>
      </view>
    </view>
  </view>
  
  <view class="results" id="results-section" wx:if="{{results.length > 0}}">
    <text class="results-title">计算结果</text>
    <view class="table-container">
      <view class="table-header">
        <text class="col-year">年份</text>
        <text class="col-expense">{{financeMode === 'saving' ? '年储蓄' : '年支出'}}</text>
        <text class="col-interest">年利息</text>
        <text class="col-principal">本金</text>
      </view>
      <view class="table-body">
        <view class="table-row" wx:for="{{results}}" wx:key="index">
          <text class="col-year">{{item.year}}</text>
          <text class="col-expense">{{item.expense}}</text>
          <text class="col-interest">{{item.interest}}</text>
          <text class="col-principal">{{item.principal}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<tab-bar active="calculator"/>

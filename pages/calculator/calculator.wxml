<!-- pages/calculator/calculator.wxml -->
<view class="page-content">
  <!-- 自定义顶部区域，用于适配安全区域 -->
  <view class="status-bar" style="height:{{statusBarHeight}}px;"></view>
  <view class="custom-nav">
    <text class="nav-title">Fire计算器</text>
  </view>
  
  <view class="form">
    <view class="input-group">
      <text class="label">年初本金 (元)</text>
      <input class="{{principalInputClass || 'input input-default'}}" type="digit" bindinput="onPrincipalInput" bindfocus="onPrincipalFocus" bindblur="onPrincipalBlur" value="{{principal}}" />
    </view>
    
    <view class="input-group">
      <text class="label">年收入 (元)</text>
      <input class="{{incomeInputClass || 'input input-default'}}" type="digit" bindinput="onIncomeInput" bindfocus="onIncomeFocus" bindblur="onIncomeBlur" value="{{income}}" />
    </view>
    
    <view class="input-group">
      <text class="label">年支出 (元)</text>
      <input class="{{expenseInputClass || 'input input-default'}}" type="digit" bindinput="onExpenseInput" bindfocus="onExpenseFocus" bindblur="onExpenseBlur" value="{{expense}}" />
    </view>
    
    <view class="input-group">
      <text class="label">年投资回报率 (%)</text>
      <input class="{{interestRateInputClass || 'input input-default'}}" type="digit" bindinput="onInterestRateInput" bindfocus="onInterestRateFocus" bindblur="onInterestRateBlur" value="{{interestRate}}" />
    </view>
    
    <view class="input-group">
      <text class="label">通胀率 (%)</text>
      <input class="{{inflationRateInputClass || 'input input-default'}}" type="digit" bindinput="onInflationRateInput" bindfocus="onInflationRateFocus" bindblur="onInflationRateBlur" value="{{inflationRate}}" />
    </view>
    
    <view class="input-group">
      <text class="label">计算年数</text>
      <input class="{{yearsInputClass || 'input input-default'}}" type="number" bindinput="onYearsInput" bindfocus="onYearsFocus" bindblur="onYearsBlur" value="{{years}}" />
    </view>
    
    <view class="calculate-btn" bindtap="calculate">开始计算</view>
  </view>
  
  <view class="results" wx:if="{{results.length > 0}}">
    <text class="results-title">计算结果</text>
    <view class="table-container">
      <view class="table-header">
        <text class="col-year">年份</text>
        <text class="col-expense">年支出</text>
        <text class="col-interest">年利息</text>
        <text class="col-principal">本金</text>
      </view>
      <view class="table-body">
        <view class="table-row" wx:for="{{results}}" wx:key="index">
          <text class="col-year">{{item.year}}</text>
          <text class="col-expense">{{item.expense}}</text>
          <text class="col-interest">{{item.interest}}</text>
          <text class="col-principal">{{item.principal}}</text>
        </view>
      </view>
    </view>
    
    <view class="analysis" wx:if="{{results.length > 0}}">
      <text class="analysis-title">分析与建议</text>
      <view wx:for="{{analysis}}" wx:key="index" class="analysis-item">
        <text class="analysis-text">{{item}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 自定义底部导航栏 -->
<view class="custom-bottom-nav">
  <view class="nav-item" bindtap="navigateToIndex">
    <image class="nav-icon" src="/icons/home.png"></image>
    <text class="nav-text">首页</text>
  </view>
  <view class="nav-item active">
    <image class="nav-icon" src="/icons/calculator_selected.png"></image>
    <text class="nav-text">计算器</text>
  </view>
  <view class="nav-item" bindtap="navigateToProfile">
    <image class="nav-icon" src="/icons/profile.png"></image>
    <text class="nav-text">我的</text>
  </view>
</view>
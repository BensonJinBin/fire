/* pages/index/index.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  width: 100%;
  background-color: #F5A623;
}

.custom-nav {
  background-color: #F5A623;
  padding: 20rpx 20rpx 30rpx;
  text-align: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.intro {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.intro-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
}

.info-section {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.start-btn {
  background-color: #F5A623;
  background: linear-gradient(135deg, #F5A623 0%, #E09000 100%);
  color: #333;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
  font-size: 28rpx;
  margin: 0;
  border: none;
  display: block;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  text-align: center;
  width: 100%;
}

.feature-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #FF6B35 0%, #FF8C61 100%);
}

.feature-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-icon-arbitrage {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C61 100%);
  color: white;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
}

.feature-arrow {
  font-size: 48rpx;
  color: #ccc;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.start-btn:active {
  background: linear-gradient(135deg, #E09000 0%, #CC7A00 100%);
}

.button-spacing {
  height: 20rpx;
}

.info-btn {
  background-color: #fff;
  color: #F5A623;
  border-radius: 50rpx;
  padding: 20rpx;
  font-size: 32rpx;
  margin: 20rpx;
  border: 1rpx solid #F5A623;
  display: block;
}

.info-btn:active {
  background-color: #FFF5E6;
}